# Packer Variables for Talos VM Template Creation
# Copy this file to variables.pkrvars.hcl and customize for your environment

# Proxmox connection
proxmox_api_url          = "https://proxmox.example.com:8006"
proxmox_api_token_id     = "infraflux@pam!infraflux"
proxmox_api_token_secret = "your-api-token-secret"
proxmox_node             = "proxmox-node1"

# Storage configuration
proxmox_storage_pool = "local-lvm"
proxmox_iso_storage  = "local"

# Talos configuration
talos_version = "v1.6.0"
talos_iso_file = "talos-v1.6.0-nocloud-amd64.img"

# VM template configuration
vm_id               = 9000
vm_name             = "talos-v1.6.0-template"
vm_cpu_cores        = 2
vm_memory           = 4096
vm_disk_size        = "20G"
vm_network_bridge   = "vmbr1"