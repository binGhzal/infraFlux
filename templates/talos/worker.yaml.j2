# Talos Worker Node Configuration Template
# Generated from InfraFlux v2.0 Configuration System

version: v1alpha1
debug: false
persist: true

machine:
  type: worker
  token: {{ cluster.token | default('your-cluster-token') }}

  ca:
    crt: {{ cluster.ca.crt | default('') }}
    # Note: CA key should not be present on worker nodes for security

  kubelet:
    image: ghcr.io/siderolabs/kubelet:{{ config.data.kubernetes_version }}
    extraArgs:
      # Security
      rotate-server-certificates: "true"
      protect-kernel-defaults: "true"
      tls-cipher-suites: "TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256,TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256,TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305,TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384,TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305,TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384,TLS_RSA_WITH_AES_256_GCM_SHA384,TLS_RSA_WITH_AES_128_GCM_SHA256"

      # Performance optimization
      max-pods: "110"
      kube-api-qps: "50"
      kube-api-burst: "100"
      serialize-image-pulls: "false"
      registry-qps: "10"
      registry-burst: "20"

      # Resource management
      cpu-manager-policy: "static"
      topology-manager-policy: "best-effort"

      # Monitoring
      read-only-port: "0"
      anonymous-auth: "false"
      authorization-mode: "Webhook"
      authentication-token-webhook: "true"

      # Feature gates
      feature-gates: "RotateKubeletServerCertificate=true,CPUManager=true,TopologyManager=true"

  network:
    hostname: {{ node.hostname | default('worker-1') }}
    interfaces:
      - interface: eth0
        dhcp: false
        addresses:
          - {{ node.ip }}/24
        routes:
          - network: 0.0.0.0/0
            gateway: {{ network.gateway | default('10.0.0.1') }}

  # Security Configuration
  features:
    stableHostname: true
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    kubePrism:
      enabled: true
      port: 7445
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: false

  # Security Kernel Parameters
  kernel:
    modules:
      # Security modules
      - name: audit
      - name: selinux

  # Advanced Security Configuration
  install:
    disk: /dev/sda
    image: ghcr.io/siderolabs/installer:{{ config.data.talos_version }}
    wipe: false
    extraKernelArgs:
      # Security hardening
      - audit=1
      - audit_backlog_limit=8192
      - slub_debug=P
      - page_poison=1
      - slab_nomerge
      - pti=on
      - spectre_v2=on
      - spec_store_bypass_disable=on
      - l1tf=full,force
      - mds=full,nosmt
      - tsx=off
      - tsx_async_abort=full,nosmt
      - kvm.nx_huge_pages=force

  # System Security - Note: Audit configuration moved to Kubernetes API server level
  # Machine-level audit and cgroups v2 are not supported in Talos v1.10.4
  # Audit logging is configured in cluster.apiServer.auditPolicy
  # Cgroups v2 is enabled by default in modern Talos versions

  # System Configuration
  time:
    disabled: false
    servers:
      - time.cloudflare.com
      - time.nist.gov

  # Sysctls for Kubernetes and Performance
  sysctls:
    # Kubernetes networking
    net.bridge.bridge-nf-call-iptables: "1"
    net.bridge.bridge-nf-call-ip6tables: "1"
    net.ipv4.ip_forward: "1"

    # Performance optimizations
    net.core.rmem_max: "16777216"
    net.core.wmem_max: "16777216"
    net.core.rmem_default: "262144"
    net.core.wmem_default: "262144"
    net.core.netdev_max_backlog: "5000"
    net.core.netdev_budget: "600"
    net.ipv4.tcp_rmem: "4096 65536 16777216"
    net.ipv4.tcp_wmem: "4096 65536 16777216"
    net.ipv4.tcp_congestion_control: "bbr"
    net.ipv4.tcp_slow_start_after_idle: "0"

    # File system performance
    fs.file-max: "2097152"
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "524288"

    # Virtual memory optimizations
    vm.max_map_count: "262144"
    vm.swappiness: "1"
    vm.dirty_ratio: "15"
    vm.dirty_background_ratio: "5"

    # Security hardening
    kernel.dmesg_restrict: "1"
    kernel.kptr_restrict: "2"
    kernel.yama.ptrace_scope: "1"
    net.ipv4.conf.default.rp_filter: "1"
    net.ipv4.conf.all.rp_filter: "1"
    net.ipv4.conf.default.accept_source_route: "0"
    net.ipv4.conf.all.accept_source_route: "0"
    net.ipv4.conf.default.accept_redirects: "0"
    net.ipv4.conf.all.accept_redirects: "0"
    net.ipv4.conf.default.send_redirects: "0"
    net.ipv4.conf.all.send_redirects: "0"
    net.ipv4.icmp_echo_ignore_broadcasts: "1"
    net.ipv4.icmp_ignore_bogus_error_responses: "1"

cluster:
  id: {{ cluster.id | default('') }}
  secret: {{ cluster.secret | default('') }}

  controlPlane:
    endpoint: https://{{ config.data.control_plane_ips[0] }}:6443

  clusterName: {{ config.data.cluster_name }}

  network:
    dnsDomain: {{ config.data.cluster_domain }}
    podSubnets:
      {% for subnet in config.data.pod_subnets %}
      - {{ subnet }}
      {% endfor %}
    serviceSubnets:
      {% for subnet in config.data.service_subnets %}
      - {{ subnet }}
      {% endfor %}
    cni:
      name: none  # Cilium will be installed via GitOps

  proxy:
    disabled: true  # Cilium handles this

  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: false
      service:
        disabled: false