# InfraFlux v2.0 Vault Secrets Template
# Encrypt this file with: ansible-vault encrypt group_vars/all/vault.yml
# Edit with: ansible-vault edit group_vars/all/vault.yml

---
# Proxmox API credentials
vault_proxmox_api_token: "12345678-1234-1234-1234-123456789abc"

# SSH keys for VM access
vault_ssh_private_key_path: "~/.ssh/infraflux"
vault_ssh_private_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  b3BlbnNzaC1rZXktdjEAAAAABG5vbmUAAAAEbm9uZQAAAAAAAAABAAAAFwAAAAdzc2gtcn
  # Replace with your actual private key
  -----END OPENSSH PRIVATE KEY-----

vault_ssh_public_key: "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJzfFf... user@host"

# Talos cluster secrets
vault_talos_cluster_secret: "abcdef1234567890abcdef1234567890"
vault_talos_machine_token: "1234567890abcdef1234567890abcdef"

# Certificate authority keys
vault_ca_private_key: |
  -----BEGIN RSA PRIVATE KEY-----
  MIIEpAIBAAKCAQEA...
  # Replace with your actual CA private key
  -----END RSA PRIVATE KEY-----

vault_ca_certificate: |
  -----BEGIN CERTIFICATE-----
  MIIDXTCCAkWgAwIBAgIJAK...
  # Replace with your actual CA certificate
  -----END CERTIFICATE-----

# Application secrets
vault_grafana_admin_password: "secure_password_123"
vault_slack_webhook: "https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX"

# Backup credentials (for S3-compatible storage)
vault_backup_access_key: "AKIAIOSFODNN7EXAMPLE"
vault_backup_secret_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# Database passwords
vault_postgres_password: "secure_db_password_456"
vault_redis_password: "secure_redis_password_789"

# Container registry credentials (if using private registry)
vault_registry_username: "infraflux"
vault_registry_password: "registry_password_123"

# OIDC/OAuth credentials (for Authentik)
vault_oidc_client_secret: "oidc_client_secret_789"
vault_oidc_admin_password: "oidc_admin_password_456"

# Let's Encrypt email for certificate generation
vault_letsencrypt_email: "admin@example.com"

# VPN credentials (if using site-to-site VPN)
vault_vpn_psk: "very_secure_pre_shared_key_123"

# External service API keys
vault_cloudflare_api_token: "cloudflare_token_123"
vault_external_dns_secret: "external_dns_secret_456"