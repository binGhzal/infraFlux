# Packer Variables for {{ proxmox_node_name }}
# Generated by InfraFlux Ansible automation

# Proxmox connection
proxmox_api_url          = "{{ proxmox.api_url }}"
proxmox_api_token_id     = "{{ proxmox.api_user }}!{{ proxmox.api_token_id }}"
proxmox_api_token_secret = "{{ vault_proxmox_api_token }}"
proxmox_node             = "{{ proxmox_node_name }}"

# Storage configuration
proxmox_storage_pool = "{{ proxmox.storage.vm_storage }}"
proxmox_iso_storage  = "{{ proxmox.storage.template_storage }}"

# Talos configuration
talos_version  = "{{ talos_image_info.version }}"
talos_iso_file = "{{ talos_image_info.filename }}"

# VM template configuration
vm_id             = {{ node_vm_id }}
vm_name           = "{{ template_name }}"
vm_cpu_cores      = {{ vm_template_specs.cpu.cores }}
vm_memory         = {{ vm_template_specs.memory.size }}
vm_disk_size      = "{{ vm_template_specs.disks.boot.size }}"
vm_network_bridge = "{{ vm_template_specs.network.bridge }}"