# InfraFlux v2.0 - Talos Control Plane Configuration
# Node: {{ node_hostname }}
# IP: {{ node_ip }}
# Generated: {{ ansible_date_time.iso8601 }}

version: {{ talos_config.config_version }}
debug: false
persist: true

machine:
  type: controlplane
  token: {{ base_config.machine.token }}
  ca:
    crt: {{ base_config.machine.ca.crt | to_nice_yaml | indent(4) }}
    key: {{ base_config.machine.ca.key | to_nice_yaml | indent(4) }}
  certSANs:
    - {{ cluster.talos.networking.cluster_endpoint }}
    - {{ node_ip }}
{% for cp_node in groups['control_plane'] | default([]) %}
    - {{ hostvars[cp_node]['ansible_host'] | default(hostvars[cp_node]['inventory_hostname']) }}
{% endfor %}
  
  kubelet:
    image: {{ cluster.talos.kubelet_image | default('ghcr.io/siderolabs/kubelet:' + cluster.talos.kubernetes_version) }}
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    extraArgs:
      rotate-server-certificates: true
{% if hostvars[node_hostname]['node_labels'] is defined %}
    nodeLabels:
{% for key, value in hostvars[node_hostname]['node_labels'].items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if hostvars[node_hostname]['node_taints'] is defined and hostvars[node_hostname]['node_taints'] | length > 0 %}
    registerWithTaints:
{% for taint in hostvars[node_hostname]['node_taints'] %}
      - key: {{ taint.key }}
        value: {{ taint.value | default('') }}
        effect: {{ taint.effect }}
{% endfor %}
{% endif %}

  network:
    hostname: {{ node_hostname }}
{% if not network_config.force_dhcp %}
    interfaces:
      - interface: {{ hostvars[node_hostname]['network_interface'] | default('eth0') }}
        addresses:
          - {{ node_ip }}/{{ hostvars[node_hostname]['network_prefix'] | default('24') }}
        routes:
          - network: 0.0.0.0/0
            gateway: {{ hostvars[node_hostname]['gateway'] | default(network.gateway) }}
        mtu: {{ hostvars[node_hostname]['network_mtu'] | default(1500) }}
{% endif %}
    nameservers:
{% for dns in hostvars[node_hostname]['dns_servers'] | default(network_config.dns_servers) %}
      - {{ dns }}
{% endfor %}

  install:
    disk: {{ hostvars[node_hostname]['install_disk'] | default(node_config.control_plane.install_disk) }}
    image: {{ node_config.control_plane.install_image }}
    wipe: false
    extensions:
      - image: ghcr.io/siderolabs/gvisor:{{ cluster.talos.version }}
      - image: ghcr.io/siderolabs/util-linux-tools:{{ cluster.talos.version }}

  time:
    servers:
{% for ntp in network_config.ntp_servers %}
      - {{ ntp }}
{% endfor %}

  sysctls:
    net.core.somaxconn: 65535
    net.core.netdev_max_backlog: 4096
{% for key, value in hostvars[node_hostname]['sysctls'] | default({}).items() %}
    {{ key }}: {{ value }}
{% endfor %}

  systemDiskEncryption:
    ephemeral:
      provider: luks2
      keys:
        - nodeID: {}
          slot: 0

  files:
    - content: |
        # InfraFlux v2.0 Control Plane Node
        # Hostname: {{ node_hostname }}
        # Role: Control Plane
        # Generated: {{ ansible_date_time.iso8601 }}
      path: /etc/infraflux-node-info
      mode: 0644

  env:
    GRPC_GO_LOG_VERBOSITY_LEVEL: 99
    GRPC_GO_LOG_SEVERITY_LEVEL: info

cluster:
  id: {{ base_config.cluster.id }}
  secret: {{ base_config.cluster.secret }}
  controlPlane:
    endpoint: https://{{ cluster.talos.networking.cluster_endpoint }}:6443
  
  clusterName: {{ cluster.name }}
  network:
    dnsDomain: {{ cluster.talos.networking.dns_domain }}
    podSubnets:
      - {{ cluster.talos.networking.pod_subnet }}
    serviceSubnets:
      - {{ cluster.talos.networking.service_subnet }}
    cni:
      name: none  # Will be installed post-bootstrap

  token: {{ base_config.cluster.token }}
  secretboxEncryptionSecret: {{ base_config.cluster.secretboxEncryptionSecret }}
  
  ca:
    crt: {{ base_config.cluster.ca.crt | to_nice_yaml | indent(4) }}
    key: {{ base_config.cluster.ca.key | to_nice_yaml | indent(4) }}

  aggregatorCA:
    crt: {{ base_config.cluster.aggregatorCA.crt | to_nice_yaml | indent(4) }}
    key: {{ base_config.cluster.aggregatorCA.key | to_nice_yaml | indent(4) }}

  serviceAccount:
    key: {{ base_config.cluster.serviceAccount.key | to_nice_yaml | indent(4) }}

  apiServer:
    image: {{ cluster.talos.apiserver_image | default('registry.k8s.io/kube-apiserver:' + cluster.talos.kubernetes_version) }}
    extraArgs:
      feature-gates: TTLAfterFinished=true,EphemeralContainers=true
      audit-policy-file: /etc/kubernetes/audit-policy.yaml
      audit-log-path: /var/log/audit.log
      audit-log-maxage: 30
      audit-log-maxbackup: 10
      audit-log-maxsize: 100
    extraVolumes:
      - hostPath: /var/log/audit.log
        mountPath: /var/log/audit.log
        readonly: false
    
  controllerManager:
    image: {{ cluster.talos.controller_manager_image | default('registry.k8s.io/kube-controller-manager:' + cluster.talos.kubernetes_version) }}
    extraArgs:
      feature-gates: TTLAfterFinished=true,EphemeralContainers=true

  scheduler:
    image: {{ cluster.talos.scheduler_image | default('registry.k8s.io/kube-scheduler:' + cluster.talos.kubernetes_version) }}
    extraArgs:
      feature-gates: TTLAfterFinished=true,EphemeralContainers=true

  discovery:
    enabled: {{ features.cluster_discovery | default(true) }}
    registries:
      kubernetes:
        disabled: false
      service:
        disabled: true

  etcd:
    ca:
      crt: {{ base_config.cluster.etcd.ca.crt | to_nice_yaml | indent(6) }}
      key: {{ base_config.cluster.etcd.ca.key | to_nice_yaml | indent(6) }}
    
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
      experimental-initial-corrupt-check: true
      auto-compaction-mode: periodic
      auto-compaction-retention: "1"

  inlineManifests:
    - name: audit-policy
      contents: |
        apiVersion: audit.k8s.io/v1
        kind: Policy
        rules:
          - level: None
            users: ["system:kube-proxy"]
            verbs: ["watch"]
            resources:
              - group: ""
                resources: ["endpoints", "services", "services/status"]
          - level: None
            namespaces: ["kube-system"]
            verbs: ["get"]
            resources:
              - group: ""
                resources: ["configmaps"]
          - level: None
            users:
              - "system:kube-controller-manager"
              - "system:kube-scheduler"
              - "system:serviceaccount:kube-system:endpoint-controller"
            verbs: ["get", "update"]
            namespaces: ["kube-system"]
            resources:
              - group: ""
                resources: ["endpoints"]
          - level: Request
            omitStages:
              - RequestReceived
            resources:
              - group: ""
                resources: ["events"]

{% if features.stable_hostname | default(true) %}
  extraManifests:
    - https://raw.githubusercontent.com/alex1989hu/kubelet-serving-cert-approver/main/deploy/standalone-install.yaml
{% endif %}