# System configuration patch for {{ node_hostname }}
machine:
  time:
    servers:
{% for ntp in ntp_servers %}
      - {{ ntp }}
{% endfor %}
  
{% if extra_kernel_args | length > 0 %}
  kernel:
    modules:
{% for arg in extra_kernel_args %}
      - name: {{ arg }}
{% endfor %}
{% endif %}

{% if sysctls | length > 0 %}
  sysctls:
{% for key, value in sysctls.items() %}
    {{ key }}: {{ value }}
{% endfor %}
{% endif %}

{% if extra_mounts | length > 0 %}
  disks:
{% for mount in extra_mounts %}
    - device: {{ mount.device }}
      partitions:
        - mountpoint: {{ mount.mountpoint }}
          size: {{ mount.size | default('0') }}
          format: {{ mount.format | default('ext4') }}
{% endfor %}
{% endif %}