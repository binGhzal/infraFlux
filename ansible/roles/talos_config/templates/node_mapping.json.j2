{
  "cluster_info": {
    "name": "{{ cluster.name }}",
    "endpoint": "{{ cluster.talos.networking.cluster_endpoint }}",
    "talos_version": "{{ cluster.talos.version }}",
    "kubernetes_version": "{{ cluster.talos.kubernetes_version }}",
    "generated_at": "{{ ansible_date_time.iso8601 }}"
  },
  "control_plane_nodes": [
{% for cp_node in groups['control_plane'] | default([]) %}
    {
      "hostname": "{{ cp_node }}",
      "ip_address": "{{ hostvars[cp_node]['ansible_host'] | default(hostvars[cp_node]['inventory_hostname']) }}",
      "vm_id": {{ hostvars[cp_node]['vm_id'] | default('null') }},
      "proxmox_node": "{{ hostvars[cp_node]['proxmox_node'] | default('unknown') }}",
      "config_file": "controlplane/{{ cp_node }}.yaml",
      "role": "control-plane"
    }{{ ',' if not loop.last else '' }}
{% endfor %}
  ],
  "worker_nodes": [
{% for worker_node in groups['workers'] | default([]) %}
    {
      "hostname": "{{ worker_node }}",
      "ip_address": "{{ hostvars[worker_node]['ansible_host'] | default(hostvars[worker_node]['inventory_hostname']) }}",
      "vm_id": {{ hostvars[worker_node]['vm_id'] | default('null') }},
      "proxmox_node": "{{ hostvars[worker_node]['proxmox_node'] | default('unknown') }}",
      "config_file": "worker/{{ worker_node }}.yaml",
      "role": "worker"
{% if hostvars[worker_node]['storage'] is defined %}
      ,"storage_config": {{ hostvars[worker_node]['storage'] | to_json }}
{% endif %}
{% if hostvars[worker_node]['node_labels'] is defined %}
      ,"node_labels": {{ hostvars[worker_node]['node_labels'] | to_json }}
{% endif %}
    }{{ ',' if not loop.last else '' }}
{% endfor %}
  ],
  "bootstrap_node": {
    "hostname": "{{ bootstrap.bootstrap_node }}",
    "ip_address": "{{ hostvars[bootstrap.bootstrap_node]['ansible_host'] | default(hostvars[bootstrap.bootstrap_node]['inventory_hostname']) }}"
  },
  "network_configuration": {
    "cluster_endpoint": "{{ cluster.talos.networking.cluster_endpoint }}",
    "pod_subnet": "{{ cluster.talos.networking.pod_subnet }}",
    "service_subnet": "{{ cluster.talos.networking.service_subnet }}",
    "dns_domain": "{{ cluster.talos.networking.dns_domain }}"
  },
  "deployment_commands": {
    "talosctl_endpoints": [
{% for cp_node in groups['control_plane'] | default([]) %}
      "{{ hostvars[cp_node]['ansible_host'] | default(hostvars[cp_node]['inventory_hostname']) }}"{{ ',' if not loop.last else '' }}
{% endfor %}
    ],
    "kubectl_config": "./kubeconfig",
    "talos_config": "./talosconfig"
  }
}