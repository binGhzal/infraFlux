# Kubelet configuration patch for {{ node_hostname }}
machine:
  kubelet:
    extraArgs:
      rotate-server-certificates: true
{% if is_control_plane %}
      register-with-taints: node-role.kubernetes.io/control-plane=:NoSchedule
{% endif %}
{% if node_labels | length > 0 %}
    nodeLabels:
{% for key, value in node_labels.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if node_taints | length > 0 %}
    registerWithTaints:
{% for taint in node_taints %}
      - key: {{ taint.key }}
        value: {{ taint.value | default('') }}
        effect: {{ taint.effect }}
{% endfor %}
{% endif %}