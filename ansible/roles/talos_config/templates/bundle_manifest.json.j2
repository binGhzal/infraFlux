{
  "bundle_info": {
    "name": "{{ cluster.name }}_talos_configs",
    "version": "v2.0",
    "generated_at": "{{ ansible_date_time.iso8601 }}",
    "file_name": "{{ bundle_file }}",
    "checksum": "{{ bundle_checksum }}",
    "size_bytes": {{ bundle_size }}
  },
  "cluster_configuration": {
    "name": "{{ cluster.name }}",
    "talos_version": "{{ cluster.talos.version }}",
    "kubernetes_version": "{{ cluster.talos.kubernetes_version }}",
    "endpoint": "{{ cluster.talos.networking.cluster_endpoint }}"
  },
  "included_files": {
    "talosconfig": "talosconfig",
    "controlplane_configs": "controlplane_configs.tar.gz",
{% if groups['workers'] is defined and groups['workers'] | length > 0 %}
    "worker_configs": "worker_configs.tar.gz",
{% endif %}
    "deployment_script": "deploy_configs.sh",
    "node_mapping": "node_mapping.json",
    "instructions": "DEPLOYMENT_INSTRUCTIONS.md"
  },
  "node_counts": {
    "control_plane": {{ groups['control_plane'] | length if groups['control_plane'] is defined else 0 }},
    "workers": {{ groups['workers'] | length if groups['workers'] is defined else 0 }},
    "total": {{ (groups['control_plane'] | default([]) | length) + (groups['workers'] | default([]) | length) }}
  },
  "deployment_info": {
    "bootstrap_node": "{{ bootstrap.bootstrap_node }}",
    "deployment_script": "./deploy_configs.sh",
    "manual_instructions": "./DEPLOYMENT_INSTRUCTIONS.md"
  }
}