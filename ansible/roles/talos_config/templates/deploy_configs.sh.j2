#!/bin/bash
# InfraFlux v2.0 - Talos Configuration Deployment Script
# Generated: {{ ansible_date_time.iso8601 }}
# Cluster: {{ cluster.name }}

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
CLUSTER_NAME="{{ cluster.name }}"
CLUSTER_ENDPOINT="{{ cluster.talos.networking.cluster_endpoint }}"
TALOSCONFIG="./talosconfig"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  InfraFlux v2.0 - Talos Deployment${NC}"
echo -e "${BLUE}========================================${NC}"
echo -e "Cluster: ${YELLOW}${CLUSTER_NAME}${NC}"
echo -e "Endpoint: ${YELLOW}${CLUSTER_ENDPOINT}${NC}"
echo

# Check dependencies
echo -e "${BLUE}Checking dependencies...${NC}"
command -v talosctl >/dev/null 2>&1 || { echo -e "${RED}talosctl is required but not installed${NC}"; exit 1; }
command -v kubectl >/dev/null 2>&1 || { echo -e "${RED}kubectl is required but not installed${NC}"; exit 1; }

# Extract configurations
echo -e "${BLUE}Extracting configurations...${NC}"
tar -xzf controlplane_configs.tar.gz
{% if groups['workers'] is defined and groups['workers'] | length > 0 %}
tar -xzf worker_configs.tar.gz
{% endif %}

# Function to wait for node readiness
wait_for_node() {
    local node_ip="$1"
    local timeout="${2:-300}"
    local interval=10
    local elapsed=0
    
    echo -e "${YELLOW}Waiting for node ${node_ip} to be ready...${NC}"
    
    while [ $elapsed -lt $timeout ]; do
        if talosctl --talosconfig "${TALOSCONFIG}" --nodes "${node_ip}" --endpoints "${node_ip}" health >/dev/null 2>&1; then
            echo -e "${GREEN}Node ${node_ip} is ready!${NC}"
            return 0
        fi
        sleep $interval
        elapsed=$((elapsed + interval))
        echo -n "."
    done
    
    echo -e "${RED}Node ${node_ip} failed to become ready within ${timeout} seconds${NC}"
    return 1
}

# Deploy control plane configurations
echo -e "${BLUE}Deploying control plane configurations...${NC}"
{% for cp_node in groups['control_plane'] | default([]) %}
NODE_IP="{{ hostvars[cp_node]['ansible_host'] | default(hostvars[cp_node]['inventory_hostname']) }}"
echo -e "Applying config to control plane node: ${YELLOW}{{ cp_node }}${NC} (${NODE_IP})"

talosctl apply-config \
    --insecure \
    --nodes "${NODE_IP}" \
    --file "controlplane/{{ cp_node }}.yaml"

wait_for_node "${NODE_IP}" 300

{% endfor %}

# Bootstrap the cluster (first control plane node only)
BOOTSTRAP_NODE="{{ hostvars[bootstrap.bootstrap_node]['ansible_host'] | default(hostvars[bootstrap.bootstrap_node]['inventory_hostname']) }}"
echo -e "${BLUE}Bootstrapping cluster on ${YELLOW}{{ bootstrap.bootstrap_node }}${NC} (${BOOTSTRAP_NODE})...${NC}"

talosctl bootstrap \
    --nodes "${BOOTSTRAP_NODE}" \
    --endpoints "${BOOTSTRAP_NODE}" \
    --talosconfig "${TALOSCONFIG}"

# Wait for cluster to be ready
echo -e "${YELLOW}Waiting for cluster to be ready...${NC}"
sleep 60

# Generate kubeconfig
echo -e "${BLUE}Generating kubeconfig...${NC}"
talosctl kubeconfig \
    --nodes "${BOOTSTRAP_NODE}" \
    --endpoints "${BOOTSTRAP_NODE}" \
    --talosconfig "${TALOSCONFIG}" \
    ./kubeconfig

{% if groups['workers'] is defined and groups['workers'] | length > 0 %}
# Deploy worker configurations
echo -e "${BLUE}Deploying worker configurations...${NC}"
{% for worker_node in groups['workers'] %}
NODE_IP="{{ hostvars[worker_node]['ansible_host'] | default(hostvars[worker_node]['inventory_hostname']) }}"
echo -e "Applying config to worker node: ${YELLOW}{{ worker_node }}${NC} (${NODE_IP})"

talosctl apply-config \
    --insecure \
    --nodes "${NODE_IP}" \
    --file "worker/{{ worker_node }}.yaml"

wait_for_node "${NODE_IP}" 300

{% endfor %}
{% endif %}

# Final cluster health check
echo -e "${BLUE}Performing final cluster health check...${NC}"
sleep 30

# Check cluster status
echo -e "${BLUE}Cluster Status:${NC}"
kubectl --kubeconfig ./kubeconfig get nodes -o wide

echo
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}  Deployment Complete!${NC}"
echo -e "${GREEN}========================================${NC}"
echo -e "Cluster: ${YELLOW}${CLUSTER_NAME}${NC}"
echo -e "Endpoint: ${YELLOW}https://${CLUSTER_ENDPOINT}:6443${NC}"
echo -e "Kubeconfig: ${YELLOW}./kubeconfig${NC}"
echo -e "Talosconfig: ${YELLOW}./talosconfig${NC}"
echo
echo -e "${BLUE}Next Steps:${NC}"
echo "1. Export kubeconfig: export KUBECONFIG=\$(pwd)/kubeconfig"
echo "2. Install CNI: helm install cilium cilium/cilium --namespace kube-system"
echo "3. Install CSI: kubectl apply -f https://raw.githubusercontent.com/longhorn/longhorn/master/deploy/longhorn.yaml"
echo "4. Set up monitoring and logging"
echo