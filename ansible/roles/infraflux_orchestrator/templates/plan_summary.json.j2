{
  "metadata": {
    "generated_at": "{{ plan_timestamp }}",
    "infraflux_version": "v2.0",
    "cluster_name": "{{ cluster_info.name }}",
    "environment": "{{ project.environment }}"
  },
  "plan_summary": {
    "resources_to_add": {{ plan_details.resources_to_add }},
    "resources_to_change": {{ plan_details.resources_to_change }},
    "resources_to_destroy": {{ plan_details.resources_to_destroy }}
  },
  "cluster_configuration": {
    "control_plane_count": {{ cluster_info.control_plane_count }},
    "worker_count": {{ cluster_info.worker_count }},
    "total_vms": {{ cluster_info.control_plane_count | int + cluster_info.worker_count | int }}
  },
  "infrastructure_details": {
    "talos_version": "{{ cluster.talos.version }}",
    "kubernetes_version": "{{ cluster.talos.kubernetes_version }}",
    "cluster_endpoint": "{{ cluster.talos.networking.cluster_endpoint }}",
    "vm_template": "{{ vm_template_info.name if vm_template_info is defined else 'talos-' + cluster.talos.version + '-template' }}",
    "storage": "{{ proxmox.storage.vm_storage }}",
    "network_bridge": "{{ proxmox.network.vm_bridge }}"
  },
  "resource_allocation": {
    "control_plane": {
      "cpu": {{ cluster.nodes.control_plane.resources.cpu }},
      "memory": {{ cluster.nodes.control_plane.resources.memory }},
      "disk": {{ cluster.nodes.control_plane.resources.disk_size }}
    },
    "workers": {
      "cpu": {{ cluster.nodes.workers.resources.cpu }},
      "memory": {{ cluster.nodes.workers.resources.memory }},
      "disk": {{ cluster.nodes.workers.resources.disk_size }}
    }
  },
  "networking": {
    "pod_subnet": "{{ cluster.talos.networking.pod_subnet }}",
    "service_subnet": "{{ cluster.talos.networking.service_subnet }}",
    "dns_domain": "{{ cluster.talos.networking.dns_domain }}"
  }
}