PROXMOX_ENDPOINT=https://192.168.1.100:8006  # Include https://
PROXMOX_USERNAME=root@pam                     # Include @realm
PROXMOX_PASSWORD=your-actual-password         # Check for special chars
PROXMOX_INSECURE=true                        # For self-signed certs
```

