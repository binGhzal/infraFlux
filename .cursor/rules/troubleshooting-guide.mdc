#### Node Recovery with Intelligent Retry
```bash
#!/bin/bash
# Intelligent node recovery with research-based strategies

echo "## Node Recovery Process - $(date)" >> node-recovery.md
echo "Research: https://talos.dev/docs/learn-more/troubleshooting/" >> node-recovery.md

# Reset individual Talos nodes with intelligent retry
for node_ip in $(grep -o "192.168.1.20[0-9]" .env); do
  echo "### Recovering node $node_ip" >> node-recovery.md

  # Try graceful reset first
  if talosctl --nodes $node_ip reset --graceful >/dev/null 2>&1; then
    echo "✅ Graceful reset successful" >> node-recovery.md
  else
    echo "⚠️ Graceful reset failed, trying force reset" >> node-recovery.md
    talosctl --nodes $node_ip reset --force >/dev/null 2>&1
  fi

  # Wait for recovery and validate
  sleep 60
  if talosctl --nodes $node_ip version >/dev/null 2>&1; then
    echo "✅ Node $node_ip recovered successfully" >> node-recovery.md
  else
    echo "❌ Node $node_ip recovery failed" >> node-recovery.md
  fi
done

# Bootstrap only first master (research-based approach)
master_ip=$(grep -o "192.168.1.200" .env)
if [ -n "$master_ip" ]; then
  echo "Bootstrapping cluster from $master_ip" >> node-recovery.md
  talosctl --nodes $master_ip bootstrap
fi

# Validate cluster state
kubectl get nodes >> node-recovery.md 2>&1
kubectl cluster-info >> node-recovery.md 2>&1

# Commit node recovery
git add node-recovery.md
git commit -m "fix: intelligent node recovery with research-based strategies

- Nodes recovered with graceful/force reset fallback
- Cluster bootstrap from research-validated approach
- Recovery process fully automated and documented"
```

