## 🔧 **Implementation Best Practices**

### **Component Architecture with Auto-Maintenance**
Follow the established patterns with focus on automation:

**Research-Driven Resource Management:**
```typescript
/**
 * Research-Based Component Implementation
 *
 * Research Sources:
 * - Pulumi Provider: https://pulumi.com/registry/packages/proxmoxve/
 * - Proxmox API: https://pve.proxmox.com/pve-docs/api-viewer/
 * - Community Patterns: https://github.com/...
 *
 * Auto-Maintenance Features:
 * - Automatic version checking
 * - Self-healing configuration drift
 * - GitOps-driven updates
 * - Automated rollback on failures
 */

// Pattern: Research → Check existence → Create if needed → Auto-maintain
export class AutoMaintainedComponent extends pulumi.ComponentResource {
  constructor(name: string, args: ComponentArgs, opts?: pulumi.ComponentResourceOptions) {
    super('infraflux:category:AutoMaintainedComponent', name, {}, opts);

    // 1. Validate inputs with researched Joi schema patterns
    const validation = this.validateWithResearchedPatterns(args);
    if (!validation.valid) {
      throw new Error(`Invalid arguments: ${validation.errors.join(', ')}`);
    }

    // 2. Check for existing resources using researched data source patterns
    const existing = this.checkExistingWithAutoDiscovery(args);

    // 3. Create resources with auto-update capabilities
    const resources = existing.apply(exists => {
      if (exists && !args.forceRecreate) {
        return this.useExistingWithAutoMaintenance(exists);
      }
      return this.createNewWithAutoMaintenance(args);
    });

    // 4. Configure GitOps integration
    this.configureGitOpsIntegration(resources);

    // 5. Register outputs with monitoring
    this.registerOutputs({ resources });
  }
}
```

