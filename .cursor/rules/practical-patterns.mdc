### **Auto-Discovery Network Configuration**
```typescript
/**
 * Auto-discover network configuration from Proxmox bridge
 */
export class NetworkAutoDiscovery extends pulumi.ComponentResource {
  public readonly config: pulumi.Output<NetworkConfig>;

  constructor(name: string, args: { provider: proxmox.Provider; bridgeName: string }) {
    super('infraflux:network:AutoDiscovery', name, {});

    logResource('NetworkAutoDiscovery', 'Starting', {
      bridge: args.bridgeName,
      method: 'Proxmox bridge auto-discovery',
    });

    this.config = this.discoverNetworkConfig(args);
    this.registerOutputs({ config: this.config });
  }

  private discoverNetworkConfig(args: { bridgeName: string }): pulumi.Output<any> {
    const hostNetwork = pulumi.output(
      proxmox.network.getHostsOutput({ nodeName: 'pve' })
    );

    return hostNetwork.apply(data => {
      const discovered = {
        bridge: args.bridgeName,
        gateway: '192.168.1.1', // Extract from data
        subnet: '192.168.1.0/24', // Extract from data
        dns: ['1.1.1.1', '1.0.0.1'],
      };

      logResource('NetworkAutoDiscovery', 'Discovered', discovered);
      return discovered;
    });
  }
}
