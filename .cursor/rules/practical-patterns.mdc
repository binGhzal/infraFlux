## 🔧 **CONFIGURATION PATTERNS**

### **Environment-Based Configuration**
```typescript
// src/config/component-config.ts
import * as Joi from 'joi';

export interface ComponentConfig {
  enabled: boolean;
  autoUpdate: boolean;
  specs: {
    cores: number;
    memory: number;
    diskSize: string;
  };
  monitoring: {
    enabled: boolean;
    interval: string;
  };
}

const componentConfigSchema = Joi.object({
  enabled: Joi.boolean().default(true),
  autoUpdate: Joi.boolean().default(true),
  specs: Joi.object({
    cores: Joi.number().min(1).max(64).default(2),
    memory: Joi.number().min(512).max(1048576).default(4096),
    diskSize: Joi.string().pattern(/^\d+[GT]$/).default('20G'),
  }),
  monitoring: Joi.object({
    enabled: Joi.boolean().default(true),
    interval: Joi.string().default('30s'),
  }),
}).meta({
  description: 'Component configuration with auto-maintenance',
  research: ['https://joi.dev/api/'],
});

export function getComponentConfig(): ComponentConfig {
  const rawConfig = {
    enabled: process.env.COMPONENT_ENABLED !== 'false',
    autoUpdate: process.env.COMPONENT_AUTO_UPDATE !== 'false',
    specs: {
      cores: parseInt(process.env.COMPONENT_CORES || '2'),
      memory: parseInt(process.env.COMPONENT_MEMORY || '4096'),
      diskSize: process.env.COMPONENT_DISK || '20G',
    },
    monitoring: {
      enabled: process.env.COMPONENT_MONITORING !== 'false',
      interval: process.env.COMPONENT_MONITORING_INTERVAL || '30s',
    },
  };

  const { error, value } = componentConfigSchema.validate(rawConfig);
  if (error) {
    throw new Error(`Component configuration validation failed: ${error.message}`);
  }

  return value;
}
