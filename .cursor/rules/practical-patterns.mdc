# InfraFlux v2.0 - Practical Patterns & Code Templates

## 🏗️ **COMPONENT TEMPLATES**

### **Standard Pulumi Component Template**
```typescript
import * as pulumi from '@pulumi/pulumi';
import * as proxmox from '@muhlba91/pulumi-proxmoxve';
import { logResource } from '@/utils/logger';
import { retryOperation, ErrorContext } from '@/utils/error-handler';

/**
 * ComponentName - [Brief description]
 *
 * Research Sources:
 * - https://pulumi.com/registry/packages/proxmoxve/api-docs/
 * - https://pve.proxmox.com/pve-docs/api-viewer/
 *
 * Auto-Maintenance Features:
 * - [List self-updating capabilities]
 * - [Describe automated management]
 *
 * GitOps Integration:
 * - [Explain declarative management]
 */

export interface ComponentNameArgs {
  provider: proxmox.Provider;
  name: string;
  autoUpdate?: boolean;
  tags?: string[];
}

export interface ComponentNameOutput {
  id: pulumi.Output<string>;
  name: pulumi.Output<string>;
  ready: pulumi.Output<boolean>;
  status: pulumi.Output<string>;
}

export class ComponentName extends pulumi.ComponentResource {
  public readonly output: ComponentNameOutput;

  constructor(
    name: string,
    args: ComponentNameArgs,
    opts?: pulumi.ComponentResourceOptions
  ) {
    super('infraflux:category:ComponentName', name, {}, opts);

    logResource('ComponentName', 'Creating', {
      name,
      autoUpdate: args.autoUpdate ?? true,
      researchValidated: true,
    });

    // 1. Validate inputs with researched patterns
    this.validateInputs(args);

    // 2. Check for existing resources using data sources
    const existing = this.checkExisting(args);

    // 3. Create resource with error handling
    const resource = this.createResource(args, existing);

    // 4. Configure auto-maintenance
    this.configureAutoMaintenance(resource, args);

    // 5. Register outputs
    this.output = {
      id: resource.apply(r => r.id),
      name: resource.apply(r => r.name),
      ready: resource.apply(r => this.isReady(r)),
      status: resource.apply(r => r.status || 'created'),
    };

    this.registerOutputs({ output: this.output });
  }

  private validateInputs(args: ComponentNameArgs): void {
    if (!args.name || args.name.trim().length === 0) {
      throw new Error('Component name is required');
    }
  }

  private checkExisting(args: ComponentNameArgs): pulumi.Output<boolean> {
    // Use data sources to check for existing resources
    return pulumi.output(false); // Implement actual check
  }

  private createResource(args: ComponentNameArgs, existing: pulumi.Output<boolean>) {
    const context: ErrorContext = {
      component: 'ComponentName',
      operation: 'resource creation',
      resourceId: args.name,
    };

    return retryOperation(async () => {
      return new proxmox.vm.VirtualMachine(`${args.name}-resource`, {
        nodeName: 'pve',
        name: args.name,
        tags: ['infraflux-managed', ...(args.tags || [])],
      }, { provider: args.provider });
    }, context);
  }

  private configureAutoMaintenance(resource: any, args: ComponentNameArgs): void {
    if (args.autoUpdate) {
      logResource('ComponentName', 'AutoMaintenance', {
        enabled: true,
        features: ['self-updating', 'drift-correction'],
      });
    }
  }

  private isReady(resource: any): boolean {
    return resource.status === 'running';
  }
}
```

### **Data Source Checker Pattern**
```typescript
/**
 * Use this pattern to check for existing resources before creation
 */
export class ExistingResourceChecker extends pulumi.ComponentResource {
  public readonly exists: pulumi.Output<boolean>;
  public readonly resourceData: pulumi.Output<any>;

  constructor(name: string, args: { resourceId: string; provider: proxmox.Provider }) {
    super('infraflux:data:ExistingResourceChecker', name, {});

    this.resourceData = pulumi.output(
      proxmox.vm.getVirtualMachineOutput({
        vmId: parseInt(args.resourceId),
        nodeName: 'pve',
      })
    ).apply(data => data || null);

    this.exists = this.resourceData.apply(data => !!data);

    logResource('ExistingResourceChecker', 'Checking', {
      resourceId: args.resourceId,
      method: 'Pulumi data source query',
    });

    this.registerOutputs({
      exists: this.exists,
      resourceData: this.resourceData,
    });
  }
}
