### **Hosts Config Migration Helper**
```typescript
/**
 * Helper to migrate from env-based to hosts-based config
 */
export function generateHostsFromEnv(): HostsConfig {
  const masterCount = parseInt(process.env.K8S_MASTER_COUNT || '1');
  const workerCount = parseInt(process.env.K8S_WORKER_COUNT || '3');
  const baseIP = process.env.NETWORK_GATEWAY?.split('.').slice(0, 3).join('.') || '192.168.1';

  return {
    version: '1.0',
    clusters: {
      homelab: {
        network: {
          gateway: process.env.NETWORK_GATEWAY || `${baseIP}.1`,
          subnet: process.env.NETWORK_SUBNET || `${baseIP}.0/24`,
          bridge: process.env.NETWORK_BRIDGE || 'vmbr0',
        },
        masters: Array.from({ length: masterCount }, (_, i) => ({
          name: `k8s-master-${String(i + 1).padStart(2, '0')}`,
          vmId: 8000 + i,
          ip: `${baseIP}.${200 + i}`,
          cores: parseInt(process.env.K8S_MASTER_CORES || '2'),
          memory: parseInt(process.env.K8S_MASTER_MEMORY || '4096'),
          disk: process.env.K8S_MASTER_DISK || '30G',
          tags: ['master', 'control-plane'],
        })),
        workers: Array.from({ length: workerCount }, (_, i) => ({
          name: `k8s-worker-${String(i + 1).padStart(2, '0')}`,
          vmId: 8100 + i,
          ip: `${baseIP}.${210 + i}`,
          cores: parseInt(process.env.K8S_WORKER_CORES || '2'),
          memory: parseInt(process.env.K8S_WORKER_MEMORY || '4096'),
          disk: process.env.K8S_WORKER_DISK || '50G',
          tags: ['worker'],
        })),
      },
    },
  };
}

// Usage in main index.ts
const hostsConfig = fs.existsSync('./hosts.yaml')
  ? new HostsConfigLoader('hosts-config', { configPath: './hosts.yaml' }).config
  : generateHostsFromEnv();
