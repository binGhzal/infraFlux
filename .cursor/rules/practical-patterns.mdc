## 🔄 **GITOPS PATTERNS**

### **Declarative Application Deployment**
```typescript
/**
 * GitOps application deployment pattern
 */
export class GitOpsApplication extends pulumi.ComponentResource {
  public readonly ready: pulumi.Output<boolean>;

  constructor(name: string, args: {
    kubeProvider: any;
    appName: string;
    namespace: string;
    gitRepo: string;
    path: string;
  }) {
    super('infraflux:gitops:Application', name, {});

    logResource('GitOpsApplication', 'Creating', {
      app: args.appName,
      repo: args.gitRepo,
      path: args.path,
      method: 'FluxCD Kustomization',
    });

    // Create Kustomization for the application
    const kustomization = new k8s.apiextensions.CustomResource(
      `${name}-kustomization`,
      {
        apiVersion: 'kustomize.toolkit.fluxcd.io/v1',
        kind: 'Kustomization',
        metadata: {
          name: args.appName,
          namespace: 'flux-system',
        },
        spec: {
          interval: '5m',
          path: args.path,
          prune: true,
          sourceRef: {
            kind: 'GitRepository',
            name: 'flux-system',
          },
          targetNamespace: args.namespace,
        },
      },
      { provider: args.kubeProvider, parent: this }
    );

    this.ready = pulumi.output(true);
    this.registerOutputs({ ready: this.ready });
  }
}
