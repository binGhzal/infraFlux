# InfraFlux Secrets Configuration Template
# Copy this file and fill in your actual values
# NEVER commit the real values to git!

# Proxmox Configuration
PROXMOX_HOST="proxmox.example.com"
PROXMOX_PASSWORD="your-proxmox-password"
PROXMOX_USER="root@pam"

# SSH Keys
SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... your-public-key"
SSH_PRIVATE_KEY_PATH="~/.ssh/id_ed25519"

# Cloudflare (for DNS management)
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_EMAIL="your-email@example.com"

# Authentication (Authentik)
AUTHENTIK_SECRET_KEY="your-authentik-secret-key"
AUTHENTIK_DB_PASSWORD="your-db-password"

# Monitoring (AlertManager)
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# Application Secrets
NEXTCLOUD_ADMIN_PASSWORD="your-nextcloud-admin-password"
VAULTWARDEN_ADMIN_TOKEN="your-vaultwarden-admin-token"
PAPERLESS_SECRET_KEY="your-paperless-secret-key"

# JWT Tokens
JWT_SECRET="your-jwt-secret-for-applications"