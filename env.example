# InfraFlux v2.0 - Talos-Exclusive Configuration
# Copy this file to .env and set your Proxmox credentials

# === REQUIRED: Proxmox Access ===
PROXMOX_ENDPOINT=https://192.168.1.100:8006
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=your-proxmox-password

# === OPTIONAL: Advanced Configuration ===
# Everything else is auto-configured with production-ready defaults

# Talos Template Configuration (auto-managed)
TALOS_TEMPLATE_ID=9010

# Storage Configuration (optimized separation)
VM_STORAGE_POOL=local-lvm
ISO_STORAGE_POOL=local

# Network Configuration (auto-detected)
NETWORK_GATEWAY=192.168.1.1
NETWORK_SUBNET=192.168.1.0/24
NETWORK_BRIDGE=vmbr0

# Kubernetes Cluster Configuration (Talos defaults)
K8S_MASTER_COUNT=1
K8S_WORKER_COUNT=3
# Uses Talos Linux + Cilium CNI for best cloud integration

# GitOps Configuration (enabled by default)
GITOPS_ENABLED=true
GITOPS_REPO=https://github.com/your-org/gitops-repo
GITOPS_PATH=clusters/homelab

# Monitoring & Security (enabled by default)
MONITORING_ENABLED=true
ENABLE_FIREWALL=true
BACKUP_ENABLED=true

# === AUTOMATIC FEATURES ===
# ✅ Talos OS template created automatically
# ✅ Talos Linux Kubernetes cluster
# ✅ Cilium CNI for performance & cloud integration
# ✅ GitOps with FluxCD
# ✅ Prometheus + Grafana monitoring
# ✅ Automated backups
# ✅ Security hardening
# ✅ Safe VM ID ranges (8000+ cluster, 9010+ templates)

# Just set Proxmox credentials above, then run:
# pulumi up
