# InfraFlux v2.0 - Dynamically Generated Terraform Configuration
# Generated on: {{ ansible_date_time.iso8601 }}
# Cluster: {{ cluster.name }}
# Talos Version: {{ cluster.talos.version }}

terraform {
  required_version = ">= 1.5.0"
  
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = "~> 2.9"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.4"
    }
    local = {
      source  = "hashicorp/local"
      version = "~> 2.4"
    }
  }

  # Backend configuration (optional - can be configured via backend config file)
  {% if terraform_backend is defined %}
  backend "{{ terraform_backend.type }}" {
    {% for key, value in terraform_backend.config.items() %}
    {{ key }} = "{{ value }}"
    {% endfor %}
  }
  {% endif %}
}

# Provider configuration
provider "proxmox" {
  pm_api_url          = "{{ proxmox.api_url }}"
  pm_api_token_id     = "{{ proxmox.api_user }}!{{ proxmox.api_token_id }}"
  pm_api_token_secret = var.proxmox_api_token
  pm_tls_insecure     = true
  pm_parallel         = 1
  pm_timeout          = 600
  pm_debug            = false
  pm_log_enable       = true
  pm_log_file         = "terraform-provider-proxmox.log"
  pm_log_levels = {
    _default    = "debug"
    _capturelog = ""
  }
}

# Variables
variable "proxmox_api_token" {
  description = "Proxmox API token secret"
  type        = string
  sensitive   = true
}

variable "ssh_public_key" {
  description = "SSH public key for VM access"
  type        = string
  default     = "{{ vault_ssh_public_key | default('') }}"
}

variable "cluster_name" {
  description = "Kubernetes cluster name"
  type        = string
  default     = "{{ cluster.name }}"
}

# Random values for cluster secrets
resource "random_password" "talos_cluster_secret" {
  length  = 32
  special = false
}

resource "random_password" "talos_machine_token" {
  length  = 32
  special = false
}

# Local values
locals {
  cluster_name    = var.cluster_name
  talos_version   = "{{ cluster.talos.version }}"
  k8s_version     = "{{ cluster.talos.kubernetes_version }}"
  cluster_endpoint = "{{ cluster.talos.networking.cluster_endpoint }}"
  
  # Network configuration
  pod_subnet     = "{{ cluster.talos.networking.pod_subnet }}"
  service_subnet = "{{ cluster.talos.networking.service_subnet }}"
  dns_domain     = "{{ cluster.talos.networking.dns_domain }}"
  
  # Template configuration
  vm_template = "{{ vm_template_info.name if vm_template_info is defined else 'talos-' + cluster.talos.version + '-template' }}"
  
  # Common VM configuration
  common_vm_config = {
    vm_state        = "running"
    automatic_reboot = false
    boot            = "order=scsi0"
    scsihw          = "virtio-scsi-pci"
    hotplug         = "network,disk,usb"
    agent           = 1
    define_connection_info = false
    
    # Network configuration
    network {
      bridge    = "{{ proxmox.network.vm_bridge }}"
      firewall  = true
      link_down = false
      model     = "virtio"
    }
    
    # Cloud-init configuration
    os_type   = "cloud-init"
    ipconfig0 = "ip=dhcp"
    sshkeys   = var.ssh_public_key
    
    # Lifecycle management
    lifecycle {
      ignore_changes = [
        network[0].macaddr,
        disk[0].file,
        disk[1].file,
      ]
    }
  }
  
  # Tags for all VMs
  common_tags = [
    "infraflux",
    "talos-${local.talos_version}",
    "cluster-${local.cluster_name}",
    "managed-by-terraform"
  ]
}

{% if groups['control_plane'] is defined and groups['control_plane'] | length > 0 %}
# Control Plane VMs
{% for host in groups['control_plane'] %}
resource "proxmox_vm_qemu" "{{ hostvars[host]['inventory_hostname'] | replace('-', '_') }}" {
  name        = "{{ hostvars[host]['inventory_hostname'] }}"
  desc        = "Talos Control Plane Node - {{ cluster.name }}"
  target_node = "{{ hostvars[host]['proxmox_node'] }}"
  vmid        = {{ hostvars[host]['vm_id'] }}
  clone       = local.vm_template
  full_clone  = true
  
  # Hardware configuration
  cores    = {{ hostvars[host]['cpu_cores'] | default(cluster.nodes.control_plane.resources.cpu) }}
  sockets  = 1
  cpu      = "host"
  memory   = {{ hostvars[host]['memory_mb'] | default(cluster.nodes.control_plane.resources.memory) }}
  balloon  = 0
  
  # Storage configuration
  disk {
    slot     = 0
    size     = "{{ hostvars[host]['disk_size_gb'] | default(cluster.nodes.control_plane.resources.disk_size) }}G"
    type     = "scsi"
    storage  = "{{ proxmox.storage.vm_storage }}"
    iothread = 1
    ssd      = 1
    discard  = "on"
  }
  
  # Additional data disk
  disk {
    slot     = 1
    size     = "50G"
    type     = "scsi"
    storage  = "{{ proxmox.storage.vm_storage }}"
    iothread = 1
    ssd      = 1
    discard  = "on"
  }
  
  # Network configuration
  network {
    model    = "virtio"
    bridge   = "{{ proxmox.network.vm_bridge }}"
    firewall = true
    {% if network.vlans.enabled | default(false) %}
    tag      = {{ network.vlans.production_vlan | default(200) }}
    {% endif %}
  }
  
  # Cloud-init
  os_type      = "cloud-init"
  ipconfig0    = "ip={{ hostvars[host]['ansible_host'] }}/24,gw={{ network.ip_ranges.kubernetes.split('/')[0] | ipaddr('1') | ipaddr('address') }}"
  searchdomain = "{{ network.domain }}"
  nameserver   = "{{ network.dns.servers | join(' ') }}"
  sshkeys      = var.ssh_public_key
  
  # VM options
  onboot       = true
  startup      = "order=1,up=30"
  protection   = false
  
  # Tags
  tags = join(",", concat(local.common_tags, ["control-plane", "talos-role-controlplane"]))
  
  # Lifecycle
  lifecycle {
    ignore_changes = [
      network[0].macaddr,
      disk[0].file,
      disk[1].file,
    ]
  }
}

{% endfor %}
{% endif %}

{% if groups['workers'] is defined and groups['workers'] | length > 0 %}
# Worker VMs
{% for host in groups['workers'] %}
resource "proxmox_vm_qemu" "{{ hostvars[host]['inventory_hostname'] | replace('-', '_') }}" {
  name        = "{{ hostvars[host]['inventory_hostname'] }}"
  desc        = "Talos Worker Node - {{ cluster.name }}"
  target_node = "{{ hostvars[host]['proxmox_node'] }}"
  vmid        = {{ hostvars[host]['vm_id'] }}
  clone       = local.vm_template
  full_clone  = true
  
  # Hardware configuration
  cores    = {{ hostvars[host]['cpu_cores'] | default(cluster.nodes.workers.resources.cpu) }}
  sockets  = 1
  cpu      = "host"
  memory   = {{ hostvars[host]['memory_mb'] | default(cluster.nodes.workers.resources.memory) }}
  balloon  = 0
  
  # Storage configuration
  disk {
    slot     = 0
    size     = "{{ hostvars[host]['disk_size_gb'] | default(cluster.nodes.workers.resources.disk_size) }}G"
    type     = "scsi"
    storage  = "{{ proxmox.storage.vm_storage }}"
    iothread = 1
    ssd      = 1
    discard  = "on"
  }
  
  # Additional data disk for container storage
  disk {
    slot     = 1
    size     = "100G"
    type     = "scsi"
    storage  = "{{ proxmox.storage.vm_storage }}"
    iothread = 1
    ssd      = 1
    discard  = "on"
  }
  
  # Network configuration
  network {
    model    = "virtio"
    bridge   = "{{ proxmox.network.vm_bridge }}"
    firewall = true
    {% if network.vlans.enabled | default(false) %}
    tag      = {{ network.vlans.production_vlan | default(200) }}
    {% endif %}
  }
  
  # Cloud-init
  os_type      = "cloud-init"
  ipconfig0    = "ip={{ hostvars[host]['ansible_host'] }}/24,gw={{ network.ip_ranges.kubernetes.split('/')[0] | ipaddr('1') | ipaddr('address') }}"
  searchdomain = "{{ network.domain }}"
  nameserver   = "{{ network.dns.servers | join(' ') }}"
  sshkeys      = var.ssh_public_key
  
  # VM options
  onboot       = true
  startup      = "order=2,up=60"
  protection   = false
  
  # Tags
  tags = join(",", concat(local.common_tags, ["worker", "talos-role-worker"]))
  
  # Dependencies - workers start after control plane
  depends_on = [
    {% for cp_host in groups['control_plane'] | default([]) %}
    proxmox_vm_qemu.{{ hostvars[cp_host]['inventory_hostname'] | replace('-', '_') }},
    {% endfor %}
  ]
  
  # Lifecycle
  lifecycle {
    ignore_changes = [
      network[0].macaddr,
      disk[0].file,
      disk[1].file,
    ]
  }
}

{% endfor %}
{% endif %}

# Outputs
output "cluster_info" {
  description = "Cluster information"
  value = {
    name             = local.cluster_name
    talos_version    = local.talos_version
    k8s_version      = local.k8s_version
    cluster_endpoint = local.cluster_endpoint
    pod_subnet       = local.pod_subnet
    service_subnet   = local.service_subnet
    dns_domain       = local.dns_domain
  }
}

{% if groups['control_plane'] is defined and groups['control_plane'] | length > 0 %}
output "control_plane_nodes" {
  description = "Control plane node information"
  value = {
    {% for host in groups['control_plane'] %}
    "{{ hostvars[host]['inventory_hostname'] }}" = {
      vm_id       = proxmox_vm_qemu.{{ hostvars[host]['inventory_hostname'] | replace('-', '_') }}.vmid
      ip_address  = "{{ hostvars[host]['ansible_host'] }}"
      proxmox_node = "{{ hostvars[host]['proxmox_node'] }}"
      cores       = {{ hostvars[host]['cpu_cores'] | default(cluster.nodes.control_plane.resources.cpu) }}
      memory      = {{ hostvars[host]['memory_mb'] | default(cluster.nodes.control_plane.resources.memory) }}
    }{{ ',' if not loop.last }}
    {% endfor %}
  }
}
{% endif %}

{% if groups['workers'] is defined and groups['workers'] | length > 0 %}
output "worker_nodes" {
  description = "Worker node information"
  value = {
    {% for host in groups['workers'] %}
    "{{ hostvars[host]['inventory_hostname'] }}" = {
      vm_id       = proxmox_vm_qemu.{{ hostvars[host]['inventory_hostname'] | replace('-', '_') }}.vmid
      ip_address  = "{{ hostvars[host]['ansible_host'] }}"
      proxmox_node = "{{ hostvars[host]['proxmox_node'] }}"
      cores       = {{ hostvars[host]['cpu_cores'] | default(cluster.nodes.workers.resources.cpu) }}
      memory      = {{ hostvars[host]['memory_mb'] | default(cluster.nodes.workers.resources.memory) }}
    }{{ ',' if not loop.last }}
    {% endfor %}
  }
}
{% endif %}

output "talos_secrets" {
  description = "Talos cluster secrets (sensitive)"
  sensitive   = true
  value = {
    cluster_secret = random_password.talos_cluster_secret.result
    machine_token  = random_password.talos_machine_token.result
  }
}

# Local file outputs for Talos configuration
resource "local_file" "terraform_output" {
  filename = "${path.module}/terraform-output.json"
  content = jsonencode({
    cluster_info       = local.cluster_name
    control_plane_ips  = [
      {% for host in groups['control_plane'] | default([]) %}
      "{{ hostvars[host]['ansible_host'] }}"{{ ',' if not loop.last }}
      {% endfor %}
    ]
    worker_ips = [
      {% for host in groups['workers'] | default([]) %}
      "{{ hostvars[host]['ansible_host'] }}"{{ ',' if not loop.last }}
      {% endfor %}
    ]
    cluster_endpoint = local.cluster_endpoint
    talos_secrets = {
      cluster_secret = random_password.talos_cluster_secret.result
      machine_token  = random_password.talos_machine_token.result
    }
  })
  
  depends_on = [
    {% for host in groups['control_plane'] | default([]) %}
    proxmox_vm_qemu.{{ hostvars[host]['inventory_hostname'] | replace('-', '_') }},
    {% endfor %}
    {% for host in groups['workers'] | default([]) %}
    proxmox_vm_qemu.{{ hostvars[host]['inventory_hostname'] | replace('-', '_') }},
    {% endfor %}
  ]
}