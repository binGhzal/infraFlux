# InfraFlux v2.0 - Runtime Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# Required Secrets - Fill these in!
# =============================================================================

# Proxmox authentication (required for VM creation)
PROXMOX_PASSWORD="your-proxmox-root-password"

# Proxmox API Token (required for Terraform automation)
# Create in Proxmox: Datacenter -> Permissions -> API Tokens
# Format: username@realm!tokenname (e.g., root@pam!infraflux-token)
PROXMOX_API_TOKEN_ID="username@realm!tokenname"
PROXMOX_API_TOKEN_SECRET="your-api-token-secret"

# GitHub token for GitOps (optional - only if using Flux)
GITHUB_TOKEN="ghp_your-github-token"

# SSH keys (not needed for Talos deployment - Talos uses API, not SSH)
# Uncomment if you plan to add GitOps or need VM SSH access in the future
# SSH_PUBLIC_KEY="ssh-rsa AAAAB3NzaC1yc2E... your-public-key"
# SSH_PRIVATE_KEY_PATH="~/.ssh/id_rsa"  # For Git operations

# =============================================================================
# Optional Runtime Settings
# =============================================================================

# Debug mode
DEBUG="false"
ANSIBLE_VERBOSITY="0"

# Deployment options
SKIP_VALIDATION="false"
FORCE_REBUILD="false"
