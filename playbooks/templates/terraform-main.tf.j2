# InfraFlux v2.0 Terraform Configuration
# Generated by Ansible with Jinja2

terraform {
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = "3.0.1-rc9"  # Latest stable RC - v3.0.2-rc01 has checksum issues
    }
  }
  required_version = ">= 1.0"
}

provider "proxmox" {
  pm_api_url  = var.proxmox.endpoint

  # Use API token if provided, otherwise fall back to password auth
  pm_api_token_id     = var.proxmox.api_token_id
  pm_api_token_secret = var.proxmox.api_token_secret

  pm_tls_insecure = var.proxmox.insecure
}

# Virtual Machines (Control Plane + Workers)
resource "proxmox_virtual_environment_vm" "cluster_nodes" {
  for_each = var.nodes

  node_name = each.value.host_node
  name      = each.key
  description = each.value.machine_type == "controlplane" ? "Talos Control Plane" : "Talos Worker"
  tags      = each.value.machine_type == "controlplane" ? ["infraflux", "talos", "control-plane"] : ["infraflux", "talos", "worker"]
  on_boot   = true
  vm_id     = each.value.vm_id

  machine       = "q35"
  scsi_hardware = "virtio-scsi-single"
  bios          = "seabios"

  agent {
    enabled = true
  }

  cpu {
    cores = each.value.cpu
    type  = "host"
  }

  memory {
    dedicated = each.value.ram_dedicated
  }

  network_device {
    bridge      = "{{ config.spec.infrastructure.proxmox.bridge | default('vmbr0') }}"
    mac_address = each.value.mac_address
  }

  disk {
    datastore_id = each.value.datastore_id
    interface    = "scsi0"
    iothread     = true
    cache        = "writethrough"
    discard      = "on"
    ssd          = true
    file_format  = "raw"
    size         = each.value.disk_size
  }

  boot_order = ["scsi0"]

  operating_system {
    type = "l26" # Linux Kernel 2.6 - 6.X
  }

  initialization {
    datastore_id = each.value.datastore_id
    ip_config {
      ipv4 {
        address = "${each.value.ip}/24"
        gateway = var.cluster.gateway
      }
    }
  }

  # Optional iGPU passthrough
  dynamic "hostpci" {
    for_each = each.value.igpu ? [1] : []
    content {
      device  = "hostpci0"
      mapping = "iGPU"
      pcie    = true
      rombar  = true
      xvga    = false
    }
  }
}

# Outputs
output "control_plane_ips" {
  description = "IP addresses of control plane nodes"
  value = [for k, v in var.nodes : v.ip if v.machine_type == "controlplane"]
}

output "worker_ips" {
  description = "IP addresses of worker nodes"
  value = [for k, v in var.nodes : v.ip if v.machine_type == "worker"]
}

output "cluster_endpoint" {
  description = "Kubernetes API endpoint"
  value = var.cluster.endpoint
}

output "cluster_name" {
  description = "Name of the cluster"
  value = var.cluster.name
}