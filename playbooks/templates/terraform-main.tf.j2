# InfraFlux v2.0 Terraform Configuration
# Generated by Ansible with Jinja2

terraform {
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = "3.0.1-rc9"  # Latest stable RC - v3.0.2-rc01 has checksum issues
    }
  }
  required_version = ">= 1.0"
}

provider "proxmox" {
  pm_api_url  = "https://{{ proxmox_host }}:8006/api2/json"
{% if lookup('env', 'PROXMOX_API_TOKEN_ID') %}
  pm_api_token_id     = "{{ lookup('env', 'PROXMOX_API_TOKEN_ID') }}"
  pm_api_token_secret = "{{ lookup('env', 'PROXMOX_API_TOKEN_SECRET') }}"
{% else %}
  pm_user     = "{{ proxmox_user }}"
  pm_password = "{{ lookup('env', 'PROXMOX_PASSWORD') }}"
{% endif %}
  pm_tls_insecure = {{ config.spec.infrastructure.proxmox.tls_insecure | default(false) | lower }}
}

# Control Plane VMs
resource "proxmox_vm_qemu" "control_plane" {
  count       = {{ control_plane_ips | length }}
  name        = "{{ cluster_name }}-cp-${count.index + 1}"
  target_node = "{{ proxmox_node }}"
  
  # Boot order - ISO will be attached manually or via post-creation
  boot    = "order=scsi0;ide2"
  
  # VM Resources
  cores    = {{ vm_cores }}
  memory   = {{ vm_memory }}
  balloon  = 0
  numa     = false
  cpu_type = "host"
  
  # Network
  network {
    id      = 0
    model   = "virtio"
    bridge  = "{{ vm_network_bridge }}"
    macaddr = format("02:00:00:01:01:%02x", count.index + 1)
  }
  
  # Storage
  disk {
    slot     = "scsi0"
    size     = "{{ vm_disk_size }}"
    type     = "disk"
    storage  = "{{ proxmox_storage }}"
    iothread = true
    discard  = true
  }
  
  # Talos settings
  os_type = "other"
  agent   = 1
  onboot  = true
  
  # Serial console
  serial {
    id   = 0
    type = "socket"
  }
  
  tags = "infraflux,talos,controlplane"
}

# Worker VMs
resource "proxmox_vm_qemu" "worker" {
  count       = {{ worker_ips | length }}
  name        = "{{ cluster_name }}-worker-${count.index + 1}"
  target_node = "{{ proxmox_node }}"
  
  # Boot order - ISO will be attached manually or via post-creation
  boot    = "order=scsi0;ide2"
  
  # VM Resources
  cores    = {{ vm_cores }}
  memory   = {{ vm_memory }}
  balloon  = 0
  numa     = false
  cpu_type = "host"
  
  # Network
  network {
    id      = 0
    model   = "virtio"
    bridge  = "{{ vm_network_bridge }}"
    macaddr = format("02:00:00:02:01:%02x", count.index + 1)
  }
  
  # Storage
  disk {
    slot     = "scsi0"
    size     = "{{ vm_disk_size }}"
    type     = "disk"
    storage  = "{{ proxmox_storage }}"
    iothread = true
    discard  = true
  }
  
  # Talos settings
  os_type = "other"
  agent   = 1
  onboot  = true
  
  # Serial console
  serial {
    id   = 0
    type = "socket"
  }
  
  tags = "infraflux,talos,worker"
}

# Outputs
output "control_plane_ips" {
  value = {{ control_plane_ips | to_json }}
}

output "worker_ips" {
  value = {{ worker_ips | to_json }}
}

output "cluster_endpoint" {
  value = "https://{{ control_plane_ips[0] }}:6443"
}