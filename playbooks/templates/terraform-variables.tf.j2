# InfraFlux v2.0 - Terraform Variables
# Generated by Ansible with Jinja2

variable "proxmox" {
  description = "Proxmox VE configuration"
  type = object({
    endpoint        = string
    api_token_id    = string
    api_token_secret = string
    insecure        = optional(bool, true)
    cluster_name    = optional(string, "{{ config.spec.infrastructure.proxmox.cluster_name | default('proxmox') }}")
  })
  sensitive = true
}

variable "cluster" {
  description = "Cluster configuration"
  type = object({
    name            = string
    endpoint        = string
    gateway         = string
    talos_version   = string
    kubernetes_version = string
    environment     = string
  })
  default = {
    name            = "{{ cluster_name }}"
    endpoint        = "https://{{ control_plane_ips[0] }}:6443"
    gateway         = "{{ config.spec.infrastructure.proxmox.gateway | default('10.0.0.1') }}"
    talos_version   = "{{ talos_version }}"
    kubernetes_version = "{{ kubernetes_version }}"
    environment     = "{{ cluster_environment }}"
  }
}

variable "image" {
  description = "Talos image configuration"
  type = object({
    factory_url     = optional(string, "https://factory.talos.dev")
    version         = string
    platform        = optional(string, "nocloud")
    arch            = optional(string, "amd64")
    proxmox_datastore = optional(string, "{{ config.spec.infrastructure.proxmox.storage | default('local') }}")
    update_version  = optional(string)
  })
  default = {
    version = "{{ talos_version }}"
  }
}

variable "nodes" {
  description = "Configuration for cluster nodes"
  type = map(object({
    host_node     = string
    machine_type  = string
    datastore_id  = optional(string, "{{ config.spec.infrastructure.proxmox.storage | default('local-lvm') }}")
    ip            = string
    mac_address   = string
    vm_id         = number
    cpu           = number
    ram_dedicated = number
    disk_size     = optional(number, 20)
    update        = optional(bool, false)
    igpu          = optional(bool, false)
  }))
  default = {
{% for ip in control_plane_ips %}
    "{{ cluster_name }}-cp-{{ loop.index }}" = {
      host_node     = "{{ config.spec.infrastructure.proxmox.node | default('pve') }}"
      machine_type  = "controlplane"
      ip            = "{{ ip }}"
      mac_address   = "02:00:00:01:01:{{ '%02x' | format(loop.index) }}"
      vm_id         = {{ 800 + loop.index0 }}
      cpu           = {{ vm_cores }}
      ram_dedicated = {{ vm_memory }}
    }
{% endfor %}
{% for ip in worker_ips %}
    "{{ cluster_name }}-worker-{{ loop.index }}" = {
      host_node     = "{{ config.spec.infrastructure.proxmox.node | default('pve') }}"
      machine_type  = "worker"
      ip            = "{{ ip }}"
      mac_address   = "02:00:00:02:01:{{ '%02x' | format(loop.index) }}"
      vm_id         = {{ 810 + loop.index0 }}
      cpu           = {{ vm_cores }}
      ram_dedicated = {{ vm_memory }}
    }
{% endfor %}
  }
}

variable "cilium" {
  description = "Cilium CNI configuration"
  type = object({
    enable_l2_announcements = optional(bool, true)
    enable_gateway_api     = optional(bool, true)
    enable_ingress        = optional(bool, true)
    load_balancer_ips     = optional(list(string), [])
  })
  default = {
    enable_l2_announcements = true
    enable_gateway_api     = true
    enable_ingress        = true
  }
}

variable "longhorn" {
  description = "Longhorn storage configuration"
  type = object({
    enable_backup       = optional(bool, false)
    backup_target      = optional(string, "")
    default_replica_count = optional(number, {{ control_plane_ips | length + worker_ips | length | int }})
  })
  default = {
    enable_backup       = false
    default_replica_count = {{ control_plane_ips | length + worker_ips | length | int }}
  }
}