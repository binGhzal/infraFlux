# Talos Worker Configuration  
# Generated by InfraFlux v2.0

version: v1alpha1
debug: false
persist: true

machine:
  type: worker
  token: {{ talos_secrets.trustdinfo.token }}
  
  ca:
    crt: {{ talos_secrets.certs.k8s.crt }}
    # Note: Workers don't get the CA key for security
  
  kubelet:
    image: ghcr.io/siderolabs/kubelet:{{ kubernetes_version }}
    extraArgs:
      rotate-server-certificates: "true"
      max-pods: "110"
  
  network:
    hostname: {{ cluster_name }}-worker-1
    interfaces:
      - interface: eth0
        dhcp: false
        addresses:
          - {{ worker_ips[0] }}/24
        routes:
          - network: 0.0.0.0/0
            gateway: {{ worker_ips[0].split('.')[0:3] | join('.') }}.1
  
  install:
    disk: /dev/sda
    image: ghcr.io/siderolabs/installer:{{ talos_version }}
    wipe: false

  time:
    disabled: false
    servers:
      - time.cloudflare.com

cluster:
  id: {{ talos_secrets.cluster.id }}
  secret: {{ talos_secrets.cluster.secret }}
  
  controlPlane:
    endpoint: https://{{ control_plane_ips[0] }}:6443
  
  clusterName: {{ cluster_name }}
  
  network:
    dnsDomain: {{ cluster_config.cluster_domain | default('cluster.local') }}
    podSubnets:
{% for subnet in cluster_config.pod_subnets %}
      - {{ subnet }}
{% endfor %}
    serviceSubnets:
{% for subnet in cluster_config.service_subnets %}
      - {{ subnet }}
{% endfor %}
    cni:
      name: none  # Cilium will be installed separately
  
  proxy:
    disabled: true  # Cilium handles this