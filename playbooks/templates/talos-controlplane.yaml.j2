# Talos Control Plane Configuration
# Generated by InfraFlux v2.0

version: v1alpha1
debug: false
persist: true

machine:
  type: controlplane
  token: {{ talos_secrets.trustdinfo.token }}
  
  ca:
    crt: {{ talos_secrets.certs.k8s.crt }}
    key: {{ talos_secrets.certs.k8s.key }}
  
  certSANs:
    - {{ control_plane_ips[0] }}
    - 127.0.0.1
    - localhost
  
  kubelet:
    image: ghcr.io/siderolabs/kubelet:{{ kubernetes_version }}
    extraArgs:
      rotate-server-certificates: "true"
  
  network:
    hostname: {{ cluster_name }}-cp-1
    interfaces:
      - interface: eth0
        dhcp: false
        addresses:
          - {{ control_plane_ips[0] }}/24
        routes:
          - network: 0.0.0.0/0
            gateway: {{ control_plane_ips[0].split('.')[0:3] | join('.') }}.1
  
  install:
    disk: /dev/sda
    image: ghcr.io/siderolabs/installer:{{ talos_version }}
    wipe: false

  time:
    disabled: false
    servers:
      - time.cloudflare.com

cluster:
  id: {{ talos_secrets.cluster.id }}
  secret: {{ talos_secrets.cluster.secret }}
  
  controlPlane:
    endpoint: https://{{ control_plane_ips[0] }}:6443
  
  clusterName: {{ cluster_name }}
  
  network:
    dnsDomain: cluster.local
    podSubnets:
      - 10.244.0.0/16
    serviceSubnets:
      - 10.96.0.0/12
    cni:
      name: none  # Cilium will be installed separately
  
  proxy:
    disabled: true  # Cilium handles this
  
  apiServer:
    image: registry.k8s.io/kube-apiserver:{{ kubernetes_version }}
    certSANs:
      - {{ control_plane_ips[0] }}
      - 127.0.0.1
      - localhost
  
  controllerManager:
    image: registry.k8s.io/kube-controller-manager:{{ kubernetes_version }}
  
  scheduler:
    image: registry.k8s.io/kube-scheduler:{{ kubernetes_version }}
  
  etcd:
    image: gcr.io/etcd-development/etcd:v3.5.15