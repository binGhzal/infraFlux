{
  "name": "infraflux-v2",
  "version": "2.0.0",
  "description": "Unified Infrastructure as Code for Proxmox homelab automation using Pulumi",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "pulumi:preview": "pulumi preview",
    "pulumi:up": "pulumi up",
    "pulumi:destroy": "pulumi destroy",
    "pulumi:refresh": "pulumi refresh",
    "pulumi:config": "pulumi config",
    "stack:create": "pulumi stack init",
    "stack:select": "pulumi stack select",
    "stack:list": "pulumi stack ls",
    "clean": "rimraf dist node_modules/.cache",
    "prepare": "husky install"
  },
  "keywords": [
    "pulumi",
    "infrastructure",
    "proxmox",
    "kubernetes",
    "talos",
    "homelab",
    "automation",
    "typescript"
  ],
  "author": "InfraFlux Team",
  "license": "MIT",
  "dependencies": {
    "@pulumi/pulumi": "^3.96.0",
    "@muhlba91/pulumi-proxmoxve": "^6.2.0",
    "@pulumi/kubernetes": "^4.5.0",
    "@pulumi/tls": "^5.0.0",
    "@pulumi/random": "^4.15.0",
    "@pulumi/command": "^0.9.0",
    "yaml": "^2.3.4",
    "lodash": "^4.17.21",
    "joi": "^17.11.0",
    "axios": "^1.6.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/lodash": "^4.14.202",
    "@types/jest": "^29.5.8",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "fast-check": "^3.15.0",
    "testcontainers": "^10.4.0",
    "rimraf": "^5.0.5",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "@pulumi/policy": "^1.8.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/infraflux.git"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ]
  }
}