{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separatePatchReleases"
  ],
  "platform": "github",
  "username": "renovate[bot]",
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "repositories": ["yourusername/infraflux"],
  "onboarding": false,
  "requireConfig": "optional",
  "schedule": [
    "before 6am every weekday",
    "every weekend"
  ],
  "timezone": "UTC",
  "labels": ["dependencies", "renovate"],
  "commitMessagePrefix": "deps:",
  "prTitle": "{{semanticPrefix}}{{#if isPin}}Pin{{else}}Update{{/if}} dependency {{depName}} to {{#if isMajor}}v{{newMajor}}{{else}}{{#if isSingleVersion}}v{{newVersion}}{{else}}{{newValue}}{{/if}}{{/if}}",
  "prBodyTemplate": "This PR updates {{depName}} from `{{currentValue}}` to `{{newValue}}`.\n\n### Release Notes\n{{{releaseNotes}}}\n\n### Configuration\n📅 **Schedule**: {{schedule}}\n🚦 **Automerge**: {{automerge}}\n♻ **Rebasing**: {{rebaseWhen}}\n🔕 **Ignore**: Close this PR and you won't be reminded about this update again.\n\n---\n\n{{#if hasReleaseNotes}}\n{{{releaseNotes}}}\n{{/if}}\n\n{{#if schedule}}\n---\n\nThis PR has been generated by [Renovate Bot](https://github.com/renovatebot/renovate).\n{{/if}}",
  "packageRules": [
    {
      "description": "Group Kubernetes and infrastructure tools",
      "groupName": "kubernetes-tools",
      "matchPackagePatterns": [
        "^k8s\\.",
        "kubernetes",
        "kubectl",
        "kustomize"
      ],
      "schedule": ["before 6am on monday"]
    },
    {
      "description": "Group monitoring stack updates",
      "groupName": "monitoring-stack",
      "matchPackagePatterns": [
        "prometheus",
        "grafana",
        "loki",
        "alertmanager"
      ],
      "schedule": ["before 6am on tuesday"]
    },
    {
      "description": "Group AI/ML platform updates",
      "groupName": "ai-ml-platform",
      "matchPackagePatterns": [
        "ollama",
        "open-webui",
        "jupyter"
      ],
      "schedule": ["before 6am on wednesday"]
    },
    {
      "description": "Group security tools",
      "groupName": "security-tools",
      "matchPackagePatterns": [
        "authentik",
        "crowdsec",
        "trivy",
        "cert-manager"
      ],
      "schedule": ["before 6am on thursday"]
    },
    {
      "description": "Group media stack updates",
      "groupName": "media-stack", 
      "matchPackagePatterns": [
        "jellyfin",
        "sonarr",
        "radarr",
        "prowlarr"
      ],
      "schedule": ["before 6am on friday"]
    },
    {
      "description": "Auto-merge patch updates for stable components",
      "matchUpdateTypes": ["patch"],
      "matchPackagePatterns": [
        "prometheus",
        "grafana"
      ],
      "automerge": true
    },
    {
      "description": "Limit concurrent PRs",
      "matchPackagePatterns": [".*"],
      "prConcurrentLimit": 5
    },
    {
      "description": "Major version updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update", "manual-review"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update container images in Kustomize files",
      "fileMatch": ["^cluster/.*/kustomization\\.ya?ml$"],
      "matchStrings": [
        "- name: (?<depName>[^\\s]+)\\s+newTag: [\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://index.docker.io"
    },
    {
      "customType": "regex", 
      "description": "Update K3s version in config",
      "fileMatch": ["^config/cluster-config\\.ya?ml$"],
      "matchStrings": [
        "k3s_version: [\"']?(?<currentValue>v[^\"'\\s]+)[\"']?"
      ],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update Helm chart versions",
      "fileMatch": ["^cluster/.*/.*\\.ya?ml$"],
      "matchStrings": [
        "chart: (?<depName>[^\\s]+)\\s+version: [\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "helm"
    }
  ],
  "regexManagers": [
    {
      "description": "Update Docker images in YAML files",
      "fileMatch": ["^cluster/.*\\.ya?ml$"],
      "matchStrings": [
        "image: (?<depName>[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "ignorePaths": [
    "**/test/**",
    "**/tests/**",
    "**/*.md",
    "docs/**"
  ]
}