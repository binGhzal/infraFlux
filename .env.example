# InfraFlux v2.0 Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Proxmox VE Configuration
# =============================================================================

# Proxmox VE API endpoint (required)
# Format: https://your-proxmox-server:8006
PROXMOX_VE_ENDPOINT=https://proxmox.example.com:8006

# Proxmox VE username (required)
# Format: username@realm (e.g., root@pam, admin@pve)
PROXMOX_VE_USERNAME=root@pam

# Authentication method 1: Password (not recommended for production)
PROXMOX_VE_PASSWORD=your-password-here

# Authentication method 2: API Token (recommended)
# Generate in Proxmox web interface: Datacenter > Permissions > API Tokens
# Format: USER@REALM!TOKENID=UUID
# PROXMOX_VE_API_TOKEN=root@pam!infraflux=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SSL Configuration
# Set to true only for development with self-signed certificates
PROXMOX_VE_INSECURE=false

# Connection timeout in seconds (default: 300)
PROXMOX_VE_TIMEOUT=300

# Maximum parallel operations (default: 4)
PROXMOX_VE_PARALLELISM=4

# Minimum TLS version (default: 1.2)
PROXMOX_VE_MIN_TLS=1.2

# =============================================================================
# Pulumi Configuration
# =============================================================================

# Pulumi backend URL (optional, defaults to Pulumi Service)
# For local state: file://./state
# For S3: s3://your-bucket-name
# PULUMI_BACKEND_URL=s3://infraflux-state

# Pulumi organization (for Pulumi Service)
# PULUMI_ORG=your-org-name

# =============================================================================
# InfraFlux Configuration
# =============================================================================

# Environment name (dev, staging, prod)
INFRAFLUX_ENVIRONMENT=dev

# Cluster configuration
INFRAFLUX_CLUSTER_NAME=homelab-dev
INFRAFLUX_CLUSTER_VERSION=v1.10.1
INFRAFLUX_NODE_COUNT=3

# Network configuration
INFRAFLUX_DOMAIN=homelab.local
INFRAFLUX_POD_SUBNET=10.244.0.0/16
INFRAFLUX_SERVICE_SUBNET=10.96.0.0/12

# VM Template configuration
INFRAFLUX_VM_TEMPLATE=talos-v1.10.1
INFRAFLUX_DATASTORE=local-lvm
INFRAFLUX_NETWORK_BRIDGE=vmbr0

# =============================================================================
# Development Configuration
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug mode
DEBUG=false

# Test configuration
TEST_TIMEOUT=30000
TEST_PROXMOX_ENDPOINT=https://test-proxmox.local:8006

# =============================================================================
# Production Security Notes
# =============================================================================

# For production deployments:
# 1. Use API tokens instead of passwords
# 2. Set PROXMOX_VE_INSECURE=false
# 3. Use a dedicated Proxmox user with minimal permissions
# 4. Store secrets in Pulumi ESC or external secret management
# 5. Enable TLS 1.2+ only
# 6. Use strong, unique passwords/tokens
# 7. Regularly rotate API tokens
# 8. Monitor access logs

# =============================================================================
# Minimal Configuration Example
# =============================================================================

# For a quick development setup, you only need:
# PROXMOX_VE_ENDPOINT=https://your-proxmox:8006
# PROXMOX_VE_USERNAME=root@pam
# PROXMOX_VE_PASSWORD=your-password
# PROXMOX_VE_INSECURE=true  # Only for dev with self-signed certs